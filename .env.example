# Confluence API Configuration
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=confluence_ingestion

# Logging Configuration
LOG_LEVEL=INFO

# Confluence Client Settings
CONFLUENCE_CLIENT_PAGE_LIMIT=50
CONFLUENCE_CLIENT_RETRIES=3

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=confluence_chunks

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_RERANK_MODEL=dengcao/Qwen3-Reranker-4B:Q4_K_M
